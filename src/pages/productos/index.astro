---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProductCard from "@/components/ProductCard.astro";
import { supabase } from "@/lib/supabase";
import type { Product } from "@/types/product";

let products: Product[] = [];
let error: string | null = null;
let totalCount = 0;

const PAGE_SIZE = 12;

const searchQuery = Astro.url.searchParams.get("q") || "";
const categoryFilter = Astro.url.searchParams.get("category") || "";
const sortParam = Astro.url.searchParams.get("sort") || "newest";
const pageParam = parseInt(Astro.url.searchParams.get("page") || "1", 10);
const currentPage = Number.isNaN(pageParam) || pageParam < 1 ? 1 : pageParam;

const SORT_OPTIONS = {
  newest:       { label: "Más recientes",       column: "created_at", ascending: false },
  "price-asc":  { label: "Precio: menor a mayor", column: "price",      ascending: true  },
  "price-desc": { label: "Precio: mayor a menor", column: "price",      ascending: false },
  "name-asc":   { label: "Nombre: A → Z",       column: "name",       ascending: true  },
  "name-desc":  { label: "Nombre: Z → A",       column: "name",       ascending: false },
} as const;

type SortKey = keyof typeof SORT_OPTIONS;
const sortKey: SortKey = (sortParam in SORT_OPTIONS ? sortParam : "newest") as SortKey;
const sort = SORT_OPTIONS[sortKey];

const from = (currentPage - 1) * PAGE_SIZE;
const to = from + PAGE_SIZE - 1;

try {
  let query = supabase
    .from("products")
    .select("*", { count: "exact" })
    .order(sort.column, { ascending: sort.ascending })
    .range(from, to);
  if (searchQuery) query = query.ilike("name", `%${searchQuery}%`);
  if (categoryFilter) query = query.eq("category", categoryFilter);

  const { data, error: dbError, count } = await query;
  if (dbError) throw new Error(dbError.message);
  products = data || [];
  totalCount = count ?? 0;
} catch (err) {
  error = err instanceof Error ? err.message : "Error al cargar los productos.";
}

const categories = ["Electrónica", "Accesorios", "Ropa", "Hogar", "Libros"];
const hasFilters = !!(searchQuery || categoryFilter || sortKey !== "newest");

const totalPages = Math.max(1, Math.ceil(totalCount / PAGE_SIZE));
const safePage = Math.min(currentPage, totalPages);
const showingFrom = totalCount === 0 ? 0 : from + 1;
const showingTo = Math.min(from + PAGE_SIZE, totalCount);

const buildPageUrl = (page: number) => {
  const params = new URLSearchParams();
  if (searchQuery) params.set("q", searchQuery);
  if (categoryFilter) params.set("category", categoryFilter);
  if (sortKey !== "newest") params.set("sort", sortKey);
  if (page > 1) params.set("page", String(page));
  const qs = params.toString();
  return qs ? `/productos?${qs}` : "/productos";
};

const buildPageRange = (current: number, total: number): (number | "…")[] => {
  if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
  const pages: (number | "…")[] = [1];
  const start = Math.max(2, current - 1);
  const end = Math.min(total - 1, current + 1);
  if (start > 2) pages.push("…");
  for (let i = start; i <= end; i++) pages.push(i);
  if (end < total - 1) pages.push("…");
  pages.push(total);
  return pages;
};

const pageRange = buildPageRange(safePage, totalPages);
---

<BaseLayout title="Catálogo" description="Explora todos los productos disponibles">
  <section class="relative gradient-mesh border-b border-stone-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
      <div class="max-w-2xl">
        <p class="text-sm font-medium text-brand-700">Catálogo</p>
        <h1 class="mt-2 font-display text-4xl sm:text-5xl font-bold tracking-tight text-stone-900 text-balance">
          Encuentra exactamente lo que buscas
        </h1>
        <p class="mt-4 text-stone-600 text-lg max-w-xl">
          {totalCount > 0
            ? `${totalCount} ${totalCount === 1 ? "producto disponible" : "productos disponibles"}`
            : "Explora nuestra colección"}
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <form class="bg-white rounded-2xl border border-stone-200 p-5 lg:p-6 shadow-sm mb-8">
      <div class="grid grid-cols-1 md:grid-cols-[1fr_auto_auto_auto] gap-3 items-end">
        <div>
          <label for="search" class="block text-xs font-semibold text-stone-700 mb-1.5 uppercase tracking-wide">
            Buscar
          </label>
          <div class="relative">
            <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input
              type="text"
              id="search"
              name="q"
              value={searchQuery}
              placeholder="Buscar productos..."
              class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-stone-200 bg-stone-50 text-sm text-stone-900 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:bg-white transition-all"
            />
          </div>
        </div>

        <div>
          <label for="category" class="block text-xs font-semibold text-stone-700 mb-1.5 uppercase tracking-wide">
            Categoría
          </label>
          <select
            id="category"
            name="category"
            class="w-full md:min-w-[180px] px-4 py-2.5 rounded-xl border border-stone-200 bg-stone-50 text-sm text-stone-900 focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:bg-white transition-all appearance-none bg-[url('data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A//www.w3.org/2000/svg%22%20fill%3D%22none%22%20viewBox%3D%220%200%2024%2024%22%20stroke%3D%22%2378716c%22%3E%3Cpath%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%20stroke-width%3D%222%22%20d%3D%22M19%209l-7%207-7-7%22%2F%3E%3C/svg%3E')] bg-no-repeat bg-[length:18px] bg-[right_0.75rem_center] pr-10"
          >
            <option value="">Todas</option>
            {categories.map((cat) => (
              <option value={cat} selected={categoryFilter === cat}>{cat}</option>
            ))}
          </select>
        </div>

        <div>
          <label for="sort" class="block text-xs font-semibold text-stone-700 mb-1.5 uppercase tracking-wide">
            Ordenar por
          </label>
          <select
            id="sort"
            name="sort"
            class="w-full md:min-w-[220px] px-4 py-2.5 rounded-xl border border-stone-200 bg-stone-50 text-sm text-stone-900 focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 focus:bg-white transition-all appearance-none bg-[url('data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A//www.w3.org/2000/svg%22%20fill%3D%22none%22%20viewBox%3D%220%200%2024%2024%22%20stroke%3D%22%2378716c%22%3E%3Cpath%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%20stroke-width%3D%222%22%20d%3D%22M19%209l-7%207-7-7%22%2F%3E%3C/svg%3E')] bg-no-repeat bg-[length:18px] bg-[right_0.75rem_center] pr-10"
          >
            {Object.entries(SORT_OPTIONS).map(([key, opt]) => (
              <option value={key} selected={sortKey === key}>{opt.label}</option>
            ))}
          </select>
        </div>

        <div class="flex gap-2">
          <button
            type="submit"
            class="px-5 py-2.5 rounded-xl gradient-brand text-white text-sm font-semibold shadow-glow hover:-translate-y-0.5 transition-all"
          >
            Aplicar
          </button>
          {hasFilters && (
            <a
              href="/productos"
              class="px-4 py-2.5 rounded-xl border border-stone-200 text-stone-700 text-sm font-medium hover:bg-stone-50 transition-all"
            >
              Limpiar
            </a>
          )}
        </div>
      </div>

      {hasFilters && (
        <div class="mt-4 flex flex-wrap items-center gap-2 pt-4 border-t border-stone-100">
          <span class="text-xs text-stone-500 font-medium">Filtros activos:</span>
          {searchQuery && (
            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-brand-50 text-brand-700 text-xs font-medium border border-brand-200">
              "{searchQuery}"
            </span>
          )}
          {categoryFilter && (
            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-brand-50 text-brand-700 text-xs font-medium border border-brand-200">
              {categoryFilter}
            </span>
          )}
          {sortKey !== "newest" && (
            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-brand-50 text-brand-700 text-xs font-medium border border-brand-200">
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 4h13M3 8h9m-9 4h6m4 0l4-4m0 0l4 4m-4-4v12" />
              </svg>
              {sort.label}
            </span>
          )}
        </div>
      )}
    </form>

    {error && (
      <div class="rounded-2xl bg-red-50 border border-red-200 p-5 flex items-start gap-3">
        <svg class="w-5 h-5 text-red-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M5.07 19h13.86c1.54 0 2.5-1.67 1.73-3L13.73 4c-.77-1.33-2.69-1.33-3.46 0L3.34 16c-.77 1.33.19 3 1.73 3z" />
        </svg>
        <div>
          <p class="font-medium text-red-800">No pudimos cargar los productos</p>
          <p class="text-sm text-red-700 mt-0.5">{error}</p>
        </div>
      </div>
    )}

    {!error && products.length === 0 && (
      <div class="text-center py-20 bg-white rounded-2xl border border-dashed border-stone-300">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-stone-100 text-stone-400 mb-4">
          <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <h3 class="font-display text-lg font-semibold text-stone-900">Sin resultados</h3>
        <p class="mt-1 text-sm text-stone-600 max-w-sm mx-auto">
          {hasFilters
            ? "No hay productos que coincidan con tu búsqueda. Prueba con otros filtros."
            : "Aún no hay productos publicados. Vuelve pronto."}
        </p>
        {hasFilters && (
          <a
            href="/productos"
            class="mt-5 inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-stone-900 text-white text-sm font-medium hover:bg-stone-800 transition-colors"
          >
            Limpiar filtros
          </a>
        )}
      </div>
    )}

    {!error && products.length > 0 && (
      <>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-6 stagger">
          {products.map((product) => (
            <ProductCard product={product} />
          ))}
        </div>

        {totalPages > 1 && (
          <nav class="mt-10 flex flex-col sm:flex-row items-center justify-between gap-4" aria-label="Paginación">
            <p class="text-sm text-stone-600">
              Mostrando <span class="font-semibold text-stone-900">{showingFrom}</span>–<span class="font-semibold text-stone-900">{showingTo}</span> de <span class="font-semibold text-stone-900">{totalCount}</span>
            </p>

            <div class="flex items-center gap-1.5">
              {safePage > 1 ? (
                <a
                  href={buildPageUrl(safePage - 1)}
                  rel="prev"
                  class="inline-flex items-center gap-1 px-3 py-2 rounded-lg border border-stone-200 bg-white text-sm font-medium text-stone-700 hover:border-brand-300 hover:text-brand-700 transition-colors"
                  aria-label="Página anterior"
                >
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                  </svg>
                  <span class="hidden sm:inline">Anterior</span>
                </a>
              ) : (
                <span class="inline-flex items-center gap-1 px-3 py-2 rounded-lg border border-stone-200 bg-stone-50 text-sm font-medium text-stone-400 cursor-not-allowed">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                  </svg>
                  <span class="hidden sm:inline">Anterior</span>
                </span>
              )}

              <div class="flex items-center gap-1">
                {pageRange.map((p) =>
                  p === "…" ? (
                    <span class="px-2 text-stone-400 text-sm">…</span>
                  ) : p === safePage ? (
                    <span
                      class="inline-flex items-center justify-center min-w-[2.5rem] h-10 px-3 rounded-lg gradient-brand text-white text-sm font-semibold shadow-glow"
                      aria-current="page"
                    >
                      {p}
                    </span>
                  ) : (
                    <a
                      href={buildPageUrl(p)}
                      class="inline-flex items-center justify-center min-w-[2.5rem] h-10 px-3 rounded-lg border border-stone-200 bg-white text-sm font-medium text-stone-700 hover:border-brand-300 hover:text-brand-700 transition-colors"
                      aria-label={`Ir a página ${p}`}
                    >
                      {p}
                    </a>
                  )
                )}
              </div>

              {safePage < totalPages ? (
                <a
                  href={buildPageUrl(safePage + 1)}
                  rel="next"
                  class="inline-flex items-center gap-1 px-3 py-2 rounded-lg border border-stone-200 bg-white text-sm font-medium text-stone-700 hover:border-brand-300 hover:text-brand-700 transition-colors"
                  aria-label="Página siguiente"
                >
                  <span class="hidden sm:inline">Siguiente</span>
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              ) : (
                <span class="inline-flex items-center gap-1 px-3 py-2 rounded-lg border border-stone-200 bg-stone-50 text-sm font-medium text-stone-400 cursor-not-allowed">
                  <span class="hidden sm:inline">Siguiente</span>
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                </span>
              )}
            </div>
          </nav>
        )}
      </>
    )}
  </div>
</BaseLayout>
