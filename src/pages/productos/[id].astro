---
import Layout from "@/layouts/Layout.astro";
import { supabase } from "@/lib/supabase";
import type { Product } from "@/types/product";

let product: Product | null = null;
let error: string | null = null;

try {
  const { id } = Astro.params;

  if (!id || isNaN(Number(id))) {
    return Astro.redirect("/productos");
  }

  const { data, error: dbError } = await supabase
    .from("products")
    .select("*")
    .eq("id", Number(id))
    .single();

  if (dbError || !data) {
    return Astro.redirect("/productos");
  }

  product = data as Product;
} catch (err) {
  error =
    err instanceof Error
      ? err.message
      : "Error al cargar el producto. Intenta más tarde.";
}
---

<Layout title={product?.name || "Producto"}>
  <div class="min-h-screen bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 py-12">
      {/* Botón volver */}
      <a
        href="/productos"
        class="inline-flex items-center text-blue-600 hover:text-blue-800 font-medium mb-8 transition"
      >
        <span class="mr-2">←</span>
        Volver al catálogo
      </a>

      {/* Mensaje de error */}
      {error && (
        <div class="p-4 bg-red-50 border border-red-200 text-red-700 rounded-lg mb-8">
          <p class="font-medium">Error</p>
          <p>{error}</p>
        </div>
      )}

      {/* Contenido del producto */}
      {product && !error && (
        <div class="bg-white rounded-lg shadow-md overflow-hidden">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 p-8">
            {/* Imagen */}
            <div class="flex items-center justify-center">
              <img
                src={product.image_url}
                alt={product.name}
                class="w-full h-auto max-h-96 object-cover rounded-lg"
              />
            </div>

            {/* Información */}
            <div class="flex flex-col justify-center">
              <span class="text-sm font-semibold text-blue-600 uppercase tracking-wide">
                {product.category}
              </span>

              <h1 class="text-4xl font-bold text-gray-900 mt-3">
                {product.name}
              </h1>

              <div class="my-6">
                <span class="text-5xl font-bold text-blue-600">
                  ${product.price.toFixed(2)}
                </span>
              </div>

              <div class="my-6 pb-6 border-b border-gray-200">
                <p class="text-gray-700 text-lg leading-relaxed">
                  {product.description}
                </p>
              </div>

              {/* Stock */}
              <div class="mb-8">
                <p class="text-sm text-gray-600 font-medium mb-2">Disponibilidad</p>
                <div
                  class={`inline-block px-4 py-2 rounded-lg font-semibold ${
                    product.stock > 0
                      ? "bg-green-100 text-green-800"
                      : "bg-red-100 text-red-800"
                  }`}
                >
                  {product.stock > 0
                    ? `${product.stock} unidades en stock`
                    : "Producto agotado"}
                </div>
              </div>

              {/* Meta información */}
              <div class="text-sm text-gray-500 border-t border-gray-200 pt-6">
                <p>ID del producto: <span class="font-mono text-gray-700">{product.id}</span></p>
                <p class="mt-2">
                  Agregado: <span class="text-gray-700">{new Date(product.created_at).toLocaleDateString('es-ES')}</span>
                </p>
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  </div>
</Layout>
