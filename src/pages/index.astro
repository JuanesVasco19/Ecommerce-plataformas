---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Inicio" description="Bienvenido a MiTienda — encuentra los mejores productos">
  <section class="flex flex-col items-center justify-center text-center px-4 py-24 bg-white">
    <h1 class="text-5xl font-bold text-gray-900 mb-4">
      Bienvenido a <span class="text-indigo-600">MiTienda</span>
    </h1>
    <p class="text-lg text-gray-500 max-w-xl mb-8">
      Encuentra los mejores productos al mejor precio. Envío rápido y seguro.
    </p>
    <a
      href="/productos"
      class="px-8 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-xl transition-colors text-lg"
    >
      Ver catálogo
    </a>
  </section>
</BaseLayout>
