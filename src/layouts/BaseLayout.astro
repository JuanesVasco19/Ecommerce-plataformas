---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'MiTienda - Tu tienda online' } = Astro.props;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | MiTienda</title>
  </head>
  <body class="min-h-screen flex flex-col bg-gray-50">
    <header class="bg-white shadow-sm border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <a href="/" class="text-xl font-bold text-indigo-600 hover:text-indigo-700 transition-colors">
            MiTienda
          </a>
          <nav class="flex gap-6">
            <a
              href="/productos"
              class="text-gray-600 hover:text-indigo-600 font-medium transition-colors"
            >
              Productos
            </a>
            <a
              href="/admin"
              class="text-gray-600 hover:text-indigo-600 font-medium transition-colors"
            >
              Admin
            </a>
          </nav>
        </div>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="bg-white border-t border-gray-200 py-6 mt-auto">
      <div class="max-w-7xl mx-auto px-4 text-center text-gray-500 text-sm">
        &copy; {year} MiTienda. Todos los derechos reservados.
      </div>
    </footer>
  </body>
</html>
